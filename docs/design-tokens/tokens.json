{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "TWallet Services — design tokens",
  "version": "1.0.0",
  "colors": {
    "primary": { "DEFAULT": "#2563EB", "hover": "#1D4ED8", "light": "#EFF6FF", "dark": "#1E40AF" },
    "success": { "DEFAULT": "#16A34A", "light": "#F0FDF4", "dark": "#15803D" },
    "warning": { "DEFAULT": "#F59E0B", "light": "#FFFBEB", "dark": "#B45309" },
    "danger": { "DEFAULT": "#DC2626", "light": "#FEF2F2", "dark": "#B91C1C" },
    "info": { "DEFAULT": "#0EA5E9", "light": "#F0F9FF" },
    "gray": {
      "50": "#F8FAFC", "100": "#F1F5F9", "200": "#E2E8F0", "300": "#CBD5E1",
      "400": "#94A3B8", "500": "#64748B", "600": "#475569", "700": "#334155",
      "800": "#1E293B", "900": "#0F172A"
    },
    "background": "#F8FAFC",
    "card": "#FFFFFF",
    "border": "#E2E8F0",
    "chart": ["#2563EB", "#F59E0B", "#10B981", "#EF4444", "#8B5CF6", "#06B6D4", "#F97316", "#EC4899"]
  },
  "spacing": {
    "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px",
    "12": "48px", "16": "64px", "20": "80px", "24": "96px"
  },
  "typography": {
    "fontFamily": { "sans": ["Inter", "system-ui", "sans-serif"], "mono": ["JetBrains Mono", "Fira Code", "monospace"] },
    "fontSize": {
      "xs": ["0.75rem", "1rem"], "sm": ["0.875rem", "1.25rem"], "base": ["1rem", "1.5rem"],
      "lg": ["1.125rem", "1.75rem"], "xl": ["1.25rem", "1.75rem"], "2xl": ["1.5rem", "2rem"],
      "3xl": ["1.875rem", "2.25rem"], "4xl": ["2.25rem", "2.5rem"], "5xl": ["3rem", "1.16"],
      "6xl": ["3.75rem", "1"]
    },
    "fontWeight": { "normal": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 }
  },
  "radius": { "sm": "8px", "md": "12px", "lg": "16px", "xl": "24px", "full": "9999px" },
  "shadows": {
    "sm": "0 1px 3px 0 rgba(0,0,0,0.04), 0 1px 2px -1px rgba(0,0,0,0.06)",
    "md": "0 4px 12px rgba(0,0,0,0.05)",
    "lg": "0 8px 24px rgba(0,0,0,0.08)",
    "xl": "0 12px 36px rgba(0,0,0,0.10)",
    "glow": "0 0 20px rgba(37,99,235,0.15)"
  },
  "animations": {
    "duration": { "fast": "150ms", "normal": "200ms", "slow": "300ms", "slower": "500ms", "slowest": "800ms" },
    "ease": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)", "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)", "in-out": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" },
  "zIndex": { "dropdown": 100, "sticky": 200, "drawer": 300, "modal": 400, "toast": 500, "tooltip": 600, "loader": 700 }
}
